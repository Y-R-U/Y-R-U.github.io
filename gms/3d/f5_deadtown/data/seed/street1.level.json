      "lines": [
        { "speaker": "Mrs. Ferro", "text": "Psst! Off the street, boy! They hear everything." },
        { "speaker": "Mrs. Ferro", "text": "It got the Hendersons. All of them. Last night." },
        { "speaker": "Mrs. Ferro", "text": "That bat won't cut it. Hanson kept a fire axe by his register — the hardware store, west side of Main." },
        { "speaker": "You", "text": "Stay inside, Mrs. Ferro. Nail it shut." }
      ] },
